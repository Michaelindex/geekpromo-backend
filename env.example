DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=change-this-in-production
DB_NAME=geekloko_db
PORT=3001

# Upload Configuration
UPLOAD_DIR=uploads/products
MAX_FILE_SIZE_MB=5
ALLOWED_MIME=image/jpeg,image/png,image/webp

# Visit Counter Configuration
VISITOR_COOKIE_NAME=gluid
VISITOR_COOKIE_MAX_DAYS=365
VISITOR_HASH_SECRET=change-this-secret-in-production-use-random-string

# Autenticação do painel admin (JWT)
# Gere o hash com: node -e "console.log(require('bcryptjs').hashSync('SUA_SENHA', 10))"
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD_HASH=change-this-bcrypt-hash-in-production
JWT_SECRET=change-this-to-a-long-random-string-in-production

# Telegram Bot Configuration
# Substitua pelos valores reais APENAS no arquivo .env (não commitar o token).
# Exemplo de URL usada internamente (NÃO colocar a URL, apenas o token):
# https://api.telegram.org/bot${TELEGRAM_BOT_TOKEN}/sendMessage
TELEGRAM_BOT_TOKEN=SEU_TOKEN_DO_BOT_AQUI
TELEGRAM_CHAT_ID=SEU_CHAT_ID_AQUI